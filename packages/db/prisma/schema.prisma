generator client {
  provider               = "prisma-client"
  output                 = "../generated/prisma"
  generatedFileExtension = "ts"
  importFileExtension    = "ts"
  moduleFormat           = "esm"
}

datasource db {
  provider = "postgresql"
}

model User {
  id              String       @id @unique @default(cuid())
  name            String
  email           String       @unique
  image           String
  role            Role         @default(USER)
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt
  contestId       String?
  problemSolved   Int          @default(0)
  createdProblems Problem[]    @relation("CreatedBy")
  problemId       Problem[]
  submission      Submission[]
  userSubmission  UserSubmission[]
  registered      ContestRegistration[]
}

model Problem {
  id           String           @id @unique @default(cuid())
  title        String
  description  String
  slug         String
  userId       String
  createdAt    DateTime         @default(now())
  updatedAt    DateTime         @updatedAt
  createdBy    String
  hidden       Boolean          @default(false)
  isApproved   SubmissionStatus @default(PENDING)
  testCase     String
  inputs       Json
  output       String
  constestId   String?
  difficulty   Difficulty
  creator      User             @relation("CreatedBy", fields: [createdBy], references: [id])
  user         User             @relation(fields: [userId], references: [id])
  starterCodes StartCode[]
  submission   Submission[]
  UserSubmission   UserSubmission[]
  contests    ContestToProblem[]
}

model Language {
  id         Int          @id @default(autoincrement())
  langauage  Languages
  startCode  StartCode[]
  Submission Submission[]
  UserSubmission UserSubmission[]
}

model StartCode {
  id         Int      @id @default(autoincrement())
  problemId  String
  languageId Int
  code       String
  language   Language @relation(fields: [languageId], references: [id])
  problems   Problem  @relation(fields: [problemId], references: [id])
}

model Submission {
  id              String           @id @default(cuid())
  userId          String
  problemId       String           @unique
  languageId      Int
  totalCorrectTc  Int @default(0)
  totalRejectedTc Int @default(0)
  outputInline    Json?
  s3URL           String?
  error           String?
  status          SubmissionStatus @default(PENDING)
  createdAt       DateTime         @default(now())
  memoryTaken     Int?             @default(0)
  timeTaken       Float?           @default(0)
  code            String
  language        Language         @relation(fields: [languageId], references: [id])
  problem         Problem          @relation(fields: [problemId], references: [id])
  user            User             @relation(fields: [userId], references: [id])
}

model  Contest{
  id          String  @id @default(cuid())
  startTime   DateTime
  endTime     DateTime
  title       String
  description String
  status      ContestStatus @default(UPCOMING)
  participant Int @default(0)
  problems    ContestToProblem[]
  registrations ContestRegistration[]
  userSubmission UserSubmission[]
  createdAt DateTime @default(now())
  updatedAt       DateTime     @updatedAt

}

model ContestToProblem{
  problemId String 
  problem Problem @relation(fields: [problemId], references: [id])
  contestId String
  contest Contest @relation(fields: [contestId], references: [id])

  problemPoint Int
  @@id([problemId, contestId])
}
model UserSubmission {
  id              String           @id @default(cuid())
  userId          String
  problemId       String           
  languageId      Int
  totalCorrectTc  Int @default(0)
  totalRejectedTc Int @default(0)
  outputInline    Json?
  error           String?
  status          SubmissionStatus @default(PENDING)
  createdAt       DateTime         @default(now())
  memoryTaken     Int?             @default(0)
  timeTaken       Float?           @default(0)
  code            String
  contestId       String?          
  contest         Contest?         @relation(fields: [contestId], references: [id])
  language        Language         @relation(fields: [languageId], references: [id])
  problem         Problem          @relation(fields: [problemId], references: [id])
  user            User             @relation(fields: [userId], references: [id])
  testcases       TestCases[]
}
model TestCases {
  id           String           @id
  submissionId String
  identity     String
  input        String
  output       String
  memoryTaken  Int?
  isHidden     Boolean          @default(false)
  timeTaken    Float?
  status       SubmissionStatus @default(PENDING)
  submissions  UserSubmission       @relation(fields: [submissionId], references: [id])
}

model ContestRegistration {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  contestId String
  contest   Contest  @relation(fields: [contestId], references: [id])
  createdAt DateTime @default(now())

  // Ensure a user can only register once per contest
  @@unique([userId, contestId]) 
}


enum Role {
  USER
  ADMIN
}
enum ContestStatus {
  UPCOMING
  ENDED
  ACTIVE
}

enum Languages {
  CPP
  JS
  RUST
}

enum Difficulty {
  EASY
  MEDIUM
  HARD
}

enum SubmissionStatus {
  ACCEPTED
  REJECTED
  PENDING
}
